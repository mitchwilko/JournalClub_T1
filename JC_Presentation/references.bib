@article{alencarNonequilibriumCytoquakeDynamics2016,
  title = {Non-Equilibrium Cytoquake Dynamics in Cytoskeletal Remodeling and Stabilization},
  author = {Alencar, Adriano Mesquita and Ferraz, Mariana Sacrini Ayres and Park, Chan Young and Millet, Emil and Trepat, Xavier and Fredberg, Jeffrey J. and Butler, James P.},
  year = 2016,
  month = oct,
  journal = {Soft Matter},
  volume = {12},
  number = {41},
  pages = {8506--8511},
  publisher = {The Royal Society of Chemistry},
  issn = {1744-6848},
  doi = {10.1039/C6SM01041E},
  urldate = {2026-04-06},
  abstract = {The cytoskeleton (CSK) is a tensed fiber framework that supports, shapes and stabilizes the cell. The CSK is in a constant state of remodeling, moreover, which is an active non-equilibrium thermodynamic process. We report here that cytoskeletal remodeling involves reconfigurations that are not only sudden but also are transmitted to great distances within the cell in a fashion reminiscent of quakes in the Earth's crust. Remarkably, these events in the cell conform both qualitatively and quantitatively to empirical laws typical of earthquakes, including hierarchical fault structures, cumulative energy distributions following the Gutenberg--Richter law, and rate of after-shocks following Omori's law. While it is well-established that remodeling and stabilization of the cytoskeleton are non-equilibrium process, these new unanticipated observations establish that these processes are also remarkably non-local and strongly cooperative.},
  langid = {english},
  file = {/Users/mitchw/Zotero/storage/MP6VFFD6/Alencar et al. - 2016 - Non-equilibrium cytoquake dynamics in cytoskeletal remodeling and stabilization.pdf}
}

@article{shiDissectingFattailedFluctuations2019,
  title = {Dissecting Fat-Tailed Fluctuations in the Cytoskeleton with Active Micropost Arrays},
  author = {Shi, Yu and Porter, Christopher L. and Crocker, John C. and Reich, Daniel H.},
  year = 2019,
  month = jul,
  journal = {Proceedings of the National Academy of Sciences},
  volume = {116},
  number = {28},
  pages = {13839--13846},
  publisher = {Proceedings of the National Academy of Sciences},
  doi = {10.1073/pnas.1900963116},
  urldate = {2026-04-06},
  abstract = {The ability of animal cells to crawl, change their shape, and respond to applied force is due to their cytoskeleton: A dynamic, cross-linked network of actin protein filaments and myosin motors. How these building blocks assemble to give rise to cells' mechanics and behavior remains poorly understood. Using active micropost array detectors containing magnetic actuators, we have characterized the mechanics and fluctuations of cells' actomyosin cortex and stress fiber network in detail. Here, we find that both structures display remarkably consistent power law viscoelastic behavior along with highly intermittent fluctuations with fat-tailed distributions of amplitudes. Notably, this motion in the cortex is dominated by occasional large, step-like displacement events, with a spatial extent of several micrometers. Overall, our findings for the cortex appear contrary to the predictions of a recent active gel model, while suggesting that different actomyosin contractile units act in a highly collective and cooperative manner. We hypothesize that cells' actomyosin components robustly self-organize into marginally stable, plastic networks that give cells' their unique biomechanical properties.},
  file = {/Users/mitchw/Zotero/storage/STRRK8N3/Shi et al. - 2019 - Dissecting fat-tailed fluctuations in the cytoskeleton with active micropost arrays.pdf}
}

